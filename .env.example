# Copy this file to ".env" and fill in the values. See SETUP_GUIDE.md.
# Never commit the real ".env" to GitHub.

# Required — emails every lead to Matan@abirlev.com (Step 2 in SETUP_GUIDE.md)
WEB3FORMS_ACCESS_KEY=

# Optional — mirror every lead into a Google Sheet (Step 3)
SHEETS_WEBHOOK_URL=

# Optional — lets people upload their tax-assessment file in the calculator (Step 4)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
