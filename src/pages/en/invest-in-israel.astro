    <div class="container process-inner">
      <div class="section-head centered" data-reveal>
        <h2 id="process-title">How It Works</h2>
      </div>
      <ol class="process-list">
        {
          steps.map((step, i) => (
            /* The <ol> already numbers these for a screen reader, so the numeral is
               decorative. "Step" and the digits are split because the body font is a
               Hebrew face whose Latin digits render undersized - the numeral needs the
               title font, the word does not. */
            <li data-reveal style={`--reveal-delay:${i * 70}ms`}>
              <span class="process-num" aria-hidden="true">
                <span class="process-num-label">Step</span>
                <span class="process-num-digits">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===== §9 key areas of focus ===== -->
