          Our firm provides overseas buyers and investors with direct, personal and comprehensive
          guidance throughout the entire process.
        </p>
        <div class="inquiry-ctas">
          <a class="btn btn--primary" href="#inquiry-form">Schedule an Introductory Call</a>
          {
            waHref && (
              <a class="btn btn--whatsapp" href={waHref} target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.5 14.4c-.3-.2-1.8-.9-2-1s-.5-.2-.7.1-.8 1-1 1.2-.4.2-.7 0a8.2 8.2 0 0 1-2.4-1.5 9 9 0 0 1-1.7-2.1c-.2-.3 0-.5.1-.6l.5-.6.3-.5v-.5l-1-2.3c-.2-.6-.5-.5-.7-.5h-.6a1.2 1.2 0 0 0-.8.4A3.4 3.4 0 0 0 5.9 9c0 1.5 1.1 3 1.2 3.2a12 12 0 0 0 4.7 4.1c.6.3 1.1.4 1.5.5.7.2 1.2.2 1.7.1.5-.1 1.6-.7 1.8-1.3.3-.7.3-1.2.2-1.3l-.5-.2ZM12 2a10 10 0 0 0-8.6 15L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.3a8.3 8.3 0 0 1-4.2-1.2l-.3-.2-3 .8.8-3-.2-.3A8.3 8.3 0 1 1 12 20.3Z" />
                </svg>
                Contact Us on WhatsApp
              </a>
            )
          }
        </div>
      </div>

      {
        accessKey ? (
          <form
            class="card inquiry-form"
            id="inquiry-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            data-investor-form
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <input
              type="hidden"
              name="subject"
              value="New overseas-investor enquiry - Adv. Matan Abir Lev"
            />
            <input type="hidden" name="from_name" value="Invest in Israel page - abirlev.com" />
            <input type="hidden" name="redirect" value={redirectUrl} />
            {/* Honeypot. Deliberately NOT named after a real autofill field (company,
                organization, …): Chrome fills those even with autocomplete="off", which
                would flag a genuine enquiry as spam and silently bin it. */}
            <input
              type="checkbox"
              name="botcheck"
              class="hp-field"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <div class="field">
              <label for="inv-name">Full Name</label>
              <input
                id="inv-name"
                name="Full Name"
                type="text"
                required
                maxlength="120"
                autocomplete="name"
              />
            </div>
            <div class="field">
              <label for="inv-email">Email</label>
              <input
                id="inv-email"
                name="Email"
                type="email"
                required
                maxlength="180"
                autocomplete="email"
              />
            </div>
            <div class="field">
              <label for="inv-phone">Phone Number</label>
              <input
                id="inv-phone"
                name="Phone Number"
                type="tel"
                required
                maxlength="40"
                autocomplete="tel"
              />
            </div>
            <div class="field">
              <label for="inv-country">Country of Residence</label>
              <input
                id="inv-country"
                name="Country of Residence"
                type="text"
                required
                maxlength="80"
                autocomplete="country-name"
              />
            </div>
            <div class="field">
              <label for="inv-area">Preferred Investment Area</label>
              <select id="inv-area" name="Preferred Investment Area" required>
                <option value="">Choose an area…</option>
                {investmentAreas.map((a) => (
                  <option>{a}</option>
                ))}
              </select>
            </div>
            <div class="field">
              <label for="inv-budget">Estimated Budget</label>
              <input
                id="inv-budget"
                name="Estimated Budget"
                type="text"
                placeholder="e.g. $1.5M - $2M"
                required
                maxlength="60"
              />
            </div>
            <div class="field">
              <label for="inv-type">Type of Property</label>
              <select id="inv-type" name="Type of Property" required>
                <option value="">Choose a property type…</option>
                {propertyTypes.map((p) => (
                  <option>{p}</option>
                ))}
              </select>
            </div>
            <div class="field">
              <label for="inv-message">Message</label>
              <textarea id="inv-message" name="Message" rows="4" required maxlength="2000" />
            </div>
            <div class="field checkbox-row">
              <input id="inv-consent" type="checkbox" name="Consent" value="Given" required />
              <label for="inv-consent">
                I consent to my details being passed to Adv. Matan Abir Lev so that he may review my
                enquiry and contact me about it.{' '}
                <a href="/privacy" lang="he">
                  Privacy Policy
                </a>
              </label>
            </div>

            <button type="submit" class="btn btn--primary">Submit Inquiry</button>
          </form>
        ) : (
          <div class="card" id="inquiry-form">
            <p class="sub">The enquiry form will go live once site setup is complete.</p>
            <p>In the meantime, please reach us on WhatsApp or by email.</p>
          </div>
        )
      }
    </div>
  </section>
</Base>

<script is:inline define:vars={{ sheetsUrl }}>
  /**
   * The enquiry must reach the mailbox AND the CRM sheet.
   *
   * The form itself is a plain HTML POST to Web3Forms - no JS needed, which is what
   * makes it work even if this script never runs. The sheet mirror rides along via
   * sendBeacon, the one API guaranteed to survive the page unloading as the browser
   * navigates to the thank-you page; a normal fetch() would be cancelled.
   *
   * With no SHEETS_WEBHOOK_URL configured this is a no-op and the email still goes.
   */
  (() => {
    const form = document.querySelector('[data-investor-form]');
    if (!form || !sheetsUrl || !navigator.sendBeacon) return;

    form.addEventListener('submit', () => {
      try {
        const data = new FormData(form);
        if (String(data.get('botcheck') ?? '') !== '') return;

        const params = new URLSearchParams();
        params.set('סוג רשומה', 'ליד משקיע מחו"ל');
        for (const [k, v] of data.entries()) {
          if (k === 'access_key' || k === 'botcheck' || k === 'redirect') continue;
          params.set(k, String(v));
        }
        params.set('תאריך יצירת ליד', new Date().toISOString());
        navigator.sendBeacon(
          sheetsUrl,
          new Blob([params.toString()], {
            type: 'application/x-www-form-urlencoded;charset=UTF-8',
          }),
        );
      } catch {
        /* the sheet is a convenience; never block the email on it */
      }
    });
  })();

  /**
   * §4 - highlight the in-page nav entry for the section you are looking at.
   * Progressive enhancement: without JS the links still jump correctly.
   */
  (() => {
    const links = Array.from(document.querySelectorAll('.pagenav a'));
    if (!links.length || !('IntersectionObserver' in window)) return;

    const byId = new Map();
    const sections = [];
    for (const link of links) {
      const id = link.getAttribute('href')?.slice(1);
      const section = id && document.getElementById(id);
      if (!section) continue;
      byId.set(section, link);
      sections.push(section);
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          links.forEach((l) => l.removeAttribute('aria-current'));
          byId.get(entry.target)?.setAttribute('aria-current', 'true');
        }
      },
      { rootMargin: '-45% 0px -50% 0px' },
    );
    sections.forEach((s) => io.observe(s));
  })();
</script>

<style>
  /* ===== hero ===== */
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    align-items: center;
    min-block-size: clamp(32rem, 78vh, 46rem);
    background: var(--c-navy-deep);
    color: var(--c-paper);
    padding-block: var(--sp-9);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    /* LTR page: the copy sits on the left, so the scrim is heaviest there */
    background-image:
      linear-gradient(
        to right,
        rgba(6, 25, 34, 0.94) 0%,
        rgba(6, 25, 34, 0.84) 40%,
        rgba(6, 25, 34, 0.5) 75%,
        rgba(6, 25, 34, 0.35) 100%
      ),
      url('/images/invest-hero.webp');
    background-size: cover, cover;
    background-position: center, center;
  }

  @media (max-width: 48rem) {
    .hero-bg {
      background-image:
        linear-gradient(to top, rgba(6, 25, 34, 0.95) 40%, rgba(6, 25, 34, 0.78) 100%),
        url('/images/invest-hero-sm.webp');
    }
  }

  .hero-inner {
    max-width: 52rem;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-small);
    font-weight: var(--fw-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-teal-bright);
    margin-block-end: var(--sp-4);
  }

  .hero-kicker::before {
    content: '';
    inline-size: 2.25rem;
    block-size: 2px;
    background: var(--c-teal-bright);
    border-radius: 2px;
  }

  .hero h1 {
    color: var(--c-paper);
    margin-block-end: var(--sp-5);
    letter-spacing: 0.01em;
  }

  .hero-sub {
    font-size: var(--fs-lead);
    font-weight: 400;
    line-height: 1.65;
    color: rgba(251, 252, 253, 0.88);
    margin-block-end: var(--sp-7);
    max-width: 38rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  /* WhatsApp is a brand action, so it carries the brand colour rather than
     pretending to be a third neutral button. */
  .btn--whatsapp {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    background: #25d366;
    color: #04331a;
    border: 1px solid #25d366;
  }

  .btn--whatsapp:hover,
  .btn--whatsapp:focus-visible {
    background: #1fbe5a;
    border-color: #1fbe5a;
    color: #04331a;
  }

  /*
    ===== §4 in-page nav =====
    Sticks directly BELOW the site header, which is itself sticky at the top of the
    viewport. --header-h is measured and published by the layout script (the header
    condenses as you scroll, so its height is not a constant); the fallback keeps
    this usable if that script never runs.
  */
  .pagenav {
    position: sticky;
    inset-block-start: var(--header-h, 4.6rem);
