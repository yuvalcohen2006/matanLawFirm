---
/**
 * INVEST IN ISRAEL - the standalone English home for overseas buyers and investors.
 *
 * Copy is the client's revision document, reproduced verbatim. Two vocabulary rules
 * from that document are load-bearing and easy to undo by accident:
 *   - the tab is INVEST IN ISRAEL, never FOREIGN INVESTORS;
 *   - people are OVERSEAS buyers/investors, never FOREIGN ones.
 * The practice-area service that points here is called INTERNATIONAL INVESTORS.
 *
 * Imagery: Tel Aviv, Jerusalem, the coastline, modern architecture. No handshakes,
 * keys, scales, gavels, law books or smiling suits.
 */
import Base from '../../layouts/Base.astro';
import site from '../../data/site-details.json';

const filled = (v: string | undefined | null): v is string =>
  Boolean(v && !v.includes('PLACEHOLDER'));

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || '';
const sheetsUrl = import.meta.env.PUBLIC_SHEETS_WEBHOOK_URL || '';
const redirectUrl = new URL('/en/thanks', Astro.site).href;

const waHref = filled(site.whatsappNumber)
  ? `https://wa.me/${site.whatsappNumber.replace(/\D/g, '')}?text=${encodeURIComponent(
      'Hello, I am interested in buying or investing in real estate in Israel.',
    )}`
  : null;

/** §4 - the in-page jump nav. Each entry must match a section id below. */
const pageNav = [
  { label: 'About Us', href: '#about' },
  { label: 'Why Choose Us', href: '#why' },
  { label: 'Our Services', href: '#services' },
  { label: 'How It Works', href: '#how' },
  { label: 'Contact', href: '#contact' },
];

/** §6 */
const whyUs = [
  {
    title: 'Local Market Knowledge',
    body: 'Extensive familiarity with the real estate markets in Central Israel and Jerusalem, including residential projects, development opportunities and key investment areas.',
  },
  {
    title: 'Direct Access to Developers',
    body: 'Strong relationships with developers and market professionals provide exposure to selected projects, pricing information and potential investment opportunities.',
  },
  {
    title: 'Legal and Commercial Perspective',
    body: 'Each transaction is reviewed from both a legal and commercial perspective, including its financial structure, risks, long-term implications and potential opportunities.',
  },
  {
    title: 'Personal Representation',
    body: 'Each client receives direct, personal and ongoing representation by Adv. Matan Abir Lev throughout the entire process.',
  },
  {
    title: 'International Experience',
    body: 'Fluent English, extensive public-speaking experience and ongoing work with international Jewish and pro-Israel communities.',
  },
];

/** §7 */
const services = [
  {
    title: 'Property Search and Opportunity Sourcing',
    body: "Identifying suitable residential and investment opportunities based on the client's objectives, budget, preferred location and investment strategy.",
  },
  {
    title: 'Access to Developers and Selected Opportunities',
    body: 'Providing exposure to selected projects, early-stage opportunities, pre-sale transactions and relevant pricing opportunities.',
  },
  {
    title: 'Legal Due Diligence',
    body: 'Comprehensive legal review of ownership rights, agreements, planning information, registrations, restrictions and relevant transaction documents.',
  },
  {
    title: 'Negotiation and Transaction Structuring',
    body: "Managing negotiations, reviewing commercial terms and structuring transactions in accordance with the client's legal and financial interests.",
  },
  {
    title: 'Israeli Real Estate Taxation',
    body: 'Reviewing purchase tax, applicable benefits, tax implications and relevant considerations for overseas buyers.',
  },
  {
    title: 'Financing and Mortgage Coordination',
    body: 'Assistance in coordinating with banks, mortgage advisers and financial professionals regarding available financing options.',
  },
  {
    title: 'Purchases from Developers',
    body: 'Legal representation in new-construction transactions, including review of developer agreements, payment schedules, guarantees, delivery provisions and buyer protections.',
  },
  {
    title: 'Professional Coordination',
    body: 'Coordination with relevant professionals, including mortgage advisers, appraisers, engineers, inspectors, accountants, notaries and property-management providers.',
  },
  {
    title: 'Closing and Post-Purchase Support',
    body: 'Ongoing guidance through execution, registration, transfer of rights, possession and completion of the transaction.',
  },
];

/** §8 */
const steps = [
  {
    title: 'Introductory Consultation',
    body: "Understanding the client's objectives, budget, preferred locations, intended use of the property and investment strategy.",
  },
  {
    title: 'Opportunity Identification',
    body: 'Identifying and presenting suitable properties, projects and investment opportunities.',
  },
  {
    title: 'Legal and Commercial Review',
    body: 'Reviewing the transaction, legal documentation, taxation, financing considerations and material risks.',
  },
  {
    title: 'Negotiation and Execution',
    body: 'Managing negotiations, reviewing and preparing agreements and coordinating the execution process.',
  },
  {
    title: 'Closing and Ongoing Support',
    body: 'Supporting the client through payments, registration, possession and post-purchase matters.',
  },
];

/** §9 */
const areas = [
  {
    title: 'Tel Aviv and Central Israel',
    body: 'Residential properties, development projects, investment opportunities and selected urban markets.',
    image: '/images/invest-telaviv.webp',
    alt: 'A penthouse terrace overlooking the Tel Aviv skyline and the Mediterranean',
  },
  {
    title: 'Jerusalem',
    body: 'Residential purchases, investment properties, new projects and opportunities tailored to overseas buyers.',
    image: '/images/invest-jerusalem.webp',
    alt: 'Jerusalem limestone architecture and the Old City walls at golden hour',
  },
  {
    title: 'Herzliya and the Coastal Region',
    body: 'Premium residential opportunities, investment properties and selected development projects.',
    image: '/images/invest-coastal.webp',
    alt: 'The Herzliya marina and seafront residential towers at blue hour',
  },
  {
    title: 'Additional Opportunities Across Israel',
    body: "Selected opportunities based on the client's objectives, investment strategy and preferred level of involvement.",
    image: '/images/invest-modern.webp',
    alt: 'A modern Israeli residential tower seen from below',
  },
];

/** §10 - the enquiry form's two select fields */
const investmentAreas = [
  'Tel Aviv and Central Israel',
  'Jerusalem',
  'Herzliya and the coastal region',
  'Open to opportunities across Israel',
];

const propertyTypes = [
  'Residential apartment',
  'New-build / off-plan from a developer',
  'Penthouse or premium residence',
  'Investment / rental property',
  'Land or development plot',
  'Commercial property',
  'Not sure yet',
];
---

<Base
  title="Invest in Israel | Adv. Matan Abir Lev - Israeli Real Estate Law"
  description="End-to-end legal and strategic representation for overseas buyers and investors purchasing property or investing in Israeli real estate: sourcing, due diligence, negotiation, taxation, financing and closing."
  lang="en"
  altHref="/"
  preloadImage="/images/invest-hero.webp"
>
  <!-- ===== §3 hero ===== -->
  <section class="hero on-dark">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="hero-kicker">Invest in Israel</p>
      <h1>Bringing You Home</h1>
      <p class="hero-sub">
        Legal, strategic and personal guidance for buying and investing in Israel.
      </p>
      <div class="hero-ctas">
        <a class="btn btn--primary" href="#services">Explore Our Services</a>
        <a class="btn btn--secondary" href="#contact">Schedule a Consultation</a>
        {
          waHref && (
            <a class="btn btn--whatsapp" href={waHref} target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.5 14.4c-.3-.2-1.8-.9-2-1s-.5-.2-.7.1-.8 1-1 1.2-.4.2-.7 0a8.2 8.2 0 0 1-2.4-1.5 9 9 0 0 1-1.7-2.1c-.2-.3 0-.5.1-.6l.5-.6.3-.5v-.5l-1-2.3c-.2-.6-.5-.5-.7-.5h-.6a1.2 1.2 0 0 0-.8.4A3.4 3.4 0 0 0 5.9 9c0 1.5 1.1 3 1.2 3.2a12 12 0 0 0 4.7 4.1c.6.3 1.1.4 1.5.5.7.2 1.2.2 1.7.1.5-.1 1.6-.7 1.8-1.3.3-.7.3-1.2.2-1.3l-.5-.2ZM12 2a10 10 0 0 0-8.6 15L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.3a8.3 8.3 0 0 1-4.2-1.2l-.3-.2-3 .8.8-3-.2-.3A8.3 8.3 0 1 1 12 20.3Z" />
              </svg>
              Contact Us on WhatsApp
            </a>
          )
        }
      </div>
    </div>
  </section>

  <!-- ===== §4 in-page navigation ===== -->
  <nav class="pagenav" aria-label="Sections of this page">
    <div class="container pagenav-inner">
      {pageNav.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </nav>

  <!-- ===== §5 about us ===== -->
  <section class="section about" id="about" aria-labelledby="about-title">
    <div class="container about-inner">
      <div class="about-photo" data-reveal>
        <img
          src={site.portraitPath}
          alt="Adv. Matan Abir Lev"
          width="560"
          height="700"
          loading="lazy"
        />
      </div>
      <div class="about-copy" data-reveal style="--reveal-delay:120ms">
        <h2 id="about-title">About Us</h2>
        <p>
          Adv. Matan Abir Lev is an Israeli real estate attorney providing personal legal and
          strategic guidance to overseas buyers and investors seeking opportunities in Israel.
        </p>
        <p>
          He completed his legal internship at one of Israel's leading real estate law firms and
          brings practical experience in real estate transactions, negotiations, development
          projects and investment opportunities.
        </p>
        <p>
          Matan is also a combat officer in the IDF Combat Engineering Corps and an experienced
          speaker for leading pro-Israel organizations, including <bdi>FIDF</bdi> and
          <bdi>CAMERA</bdi>. His work with international audiences gives him a strong understanding
          of the needs, concerns and expectations of clients purchasing property in Israel from
          abroad.
        </p>
        <p>
          The firm combines local market knowledge, direct access to developers and opportunities,
          legal protection and personal guidance throughout the entire process.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== §6 why choose us ===== -->
  <section class="section why on-dark" id="why" aria-labelledby="why-title">
    <div class="container">
      <div class="section-head centered" data-reveal>
        <h2 id="why-title">Why Choose Us</h2>
      </div>
      <ul class="why-grid">
        {
          whyUs.map((item, i) => (
            <li class="why-item" data-reveal style={`--reveal-delay:${Math.min(i, 5) * 60}ms`}>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===== §7 our services ===== -->
  <section class="section services" id="services" aria-labelledby="services-title">
    <div class="container">
      <div class="section-head centered" data-reveal>
        <h2 id="services-title">Our Services</h2>
        <p class="sub">
          End-to-end legal and strategic representation for overseas buyers and investors purchasing
          property or investing in Israeli real estate.
        </p>
      </div>
      <ul class="services-grid">
        {
          services.map((item, i) => (
            <li class="card service" data-reveal style={`--reveal-delay:${Math.min(i, 5) * 60}ms`}>
              <span class="service-num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===== §8 how it works ===== -->
