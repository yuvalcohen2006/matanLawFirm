---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityFab from '../components/AccessibilityFab.astro';
import site from '../data/site-details.json';
import { dirOf, t, EN_HOME, HE_HOME, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  /** set true on pages that should not be indexed (e.g. thank-you) */
  noindex?: boolean;
  /** hero image to preload for a faster LCP */
  preloadImage?: string;
  lang?: Lang;
  /**
   * Where this page's language switch points. Pages with a real counterpart pass
   * it; pages that only exist in one language (the calculator, the legal pages)
   * leave it out and fall back to the other language's home page.
   */
  altHref?: string;
}

const {
  title,
  description,
  noindex = false,
  preloadImage,
  lang = 'he',
  altHref,
} = Astro.props;

const s = t(lang);
const dir = dirOf(lang);
const switchHref = altHref ?? (lang === 'he' ? EN_HOME : HE_HOME);

const filled = (v: string | undefined | null): v is string =>
  Boolean(v && !v.includes('PLACEHOLDER'));

const canonical = new URL(Astro.url.pathname, Astro.site);
const alternate = new URL(switchHref, Astro.site);
const ga = filled(site.googleAnalyticsId) ? site.googleAnalyticsId : null;
const pixel = filled(site.metaPixelId) ? site.metaPixelId : null;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang === 'he' ? 'en' : 'he'} href={alternate} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    {/*
      The firm's logo EMBLEM is the site icon - tab, bookmark, search result and
      phone shortcut. The wordmark is deliberately left out: at 16px the Hebrew
      lettering is an unreadable smudge. All of these are built from public/logo.png
      by scripts/make-favicons.mjs - re-run it if the logo changes.
      favicon.ico stays because crawlers still request /favicon.ico by hard-coded path.
    */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#061922" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={lang === 'he' ? 'עו״ד מתן אביר לב' : 'Adv. Matan Abir Lev'} />

    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Alef:wght@400;700&family=Secular+One&display=swap&subset=hebrew,latin"
    />

    {
      ga && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga}');`}
          />
        </>
      )
    }
    {
      pixel && (
        <script
          is:inline
          set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${pixel}');fbq('track','PageView');`}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">{s.skipToContent}</a>
    <Header lang={lang} altHref={switchHref} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <AccessibilityFab lang={lang} />

    <script is:inline>
      // Scroll reveal + a header that condenses once you leave the top.
      // Both are progressive enhancements: with no JS, [data-reveal] elements are
      // simply visible (the CSS only hides them under prefers-reduced-motion: no-preference,
      // and we bail out entirely if the user asked for reduced motion).
      (() => {
        const calm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const targets = document.querySelectorAll('[data-reveal]');

        const show = (el) => el.classList.add('is-in');

        if (calm || !('IntersectionObserver' in window)) {
          targets.forEach(show);
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                // Reveal when visible OR when already scrolled past. Observer callbacks are
                // async: on a fast scroll (or a mid-page anchor landing) an element can be
                // reported after it has left the viewport, and a plain isIntersecting check
                // would leave it invisible forever.
                const passed = entry.boundingClientRect.top < window.innerHeight;
                if (!entry.isIntersecting && !passed) return;
                show(entry.target);
                io.unobserve(entry.target);
              });
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
          );
          targets.forEach((el) => io.observe(el));

          // Safety net: content must never stay hidden because of a missed observation.
          window.setTimeout(() => targets.forEach(show), 3000);
        }

        const header = document.querySelector('.site-header');
        if (header) {
          const onScroll = () => header.classList.toggle('is-stuck', window.scrollY > 12);
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });

          // Publish the header's height so anything that has to sit below it - a
          // page's own sticky sub-nav, the scroll-margin on anchor targets - can
          // line up with it. It is not a constant: the header condenses on scroll
          // and rewraps at narrow widths, so measure it rather than guess.
          const root = document.documentElement;
          const publish = () => root.style.setProperty('--header-h', header.offsetHeight + 'px');
          publish();
          if ('ResizeObserver' in window) new ResizeObserver(publish).observe(header);
          else window.addEventListener('resize', publish, { passive: true });
        }
      })();

      // Busy buttons.
      //
      // A spinner is a promise that something is in flight, so it only goes on
      // buttons where something really is: a form being POSTed, or a link that is
      // actually leaving this page. It deliberately does NOT go on #anchors, new
      // tabs, tel:/mailto:/WhatsApp links, or the calculator's step buttons -
      // those resolve instantly or are driven by React, and a spinner that never
      // resolves is worse than no spinner at all.
      (() => {
        const busy = (btn) => {
          if (!btn || btn.classList.contains('is-loading')) return;
          btn.classList.add('is-loading');
          btn.setAttribute('aria-busy', 'true');
        };

        // Forms: both the contact form and the investor form POST to Web3Forms and
        // then redirect, so the spinner runs until the browser leaves the page.
        document.addEventListener(
          'submit',
          (e) => {
            const form = e.target;
            if (!(form instanceof HTMLFormElement) || e.defaultPrevented) return;
            // a form with no action is handled in JS - not ours to spin
            if (!form.getAttribute('action')) return;
            busy(e.submitter || form.querySelector('button[type="submit"], .btn[type="submit"]'));
          },
          true,
        );

        document.addEventListener('click', (e) => {
          if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey)
            return;
          const link = e.target.closest && e.target.closest('a.btn');
          if (!link) return;
          if (link.target === '_blank' || link.hasAttribute('download')) return;

          const url = new URL(link.href, location.href);
          if (url.protocol !== 'http:' && url.protocol !== 'https:') return; // tel:, mailto:
          if (url.origin !== location.origin) return; // WhatsApp, Google Maps
          // same page, different hash → the browser just scrolls; nothing loads
          if (url.pathname === location.pathname && url.search === location.search) return;

          busy(link);
        });

        // Coming Back from a page restored out of the bfcache, the spinner would
        // otherwise still be turning on the button that took you away.
        window.addEventListener('pageshow', () => {
          document.querySelectorAll('.btn.is-loading').forEach((btn) => {
            btn.classList.remove('is-loading');
            btn.removeAttribute('aria-busy');
          });
        });
      })();
    </script>
  </body>
</html>
