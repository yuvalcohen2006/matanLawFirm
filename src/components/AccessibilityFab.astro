---
// Floating accessibility widget - present on every page, as required of an
// Israeli business site (תקנות שוויון זכויות לאנשים עם מוגבלות).
// Every control writes a class (or a scale variable) onto <html>; the styles
// themselves live in global.css so they can reach the whole document. Choices
// persist in localStorage so they survive navigation.
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'he' } = Astro.props;
const s = t(lang);
---

<div class="a11y">
  <button
    type="button"
    class="a11y-fab"
    aria-expanded="false"
    aria-controls="a11y-panel"
    aria-label={s.a11yOpen}
  >
    <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <circle cx="12" cy="4.2" r="1.9" />
      <path
        d="M20 6.6c-2.5.9-5.2 1.4-8 1.4s-5.5-.5-8-1.4a1.1 1.1 0 1 0-.7 2.1c1.7.6 3.5 1 5.4 1.2v2.4c0 .5-.1 1-.3 1.5l-2.3 6a1.1 1.1 0 0 0 2.1.8l2-5.2c.2-.5.5-.5.7 0l2 5.2a1.1 1.1 0 0 0 2.1-.8l-2.3-6c-.2-.5-.3-1-.3-1.5V9.9c1.9-.2 3.7-.6 5.4-1.2A1.1 1.1 0 1 0 20 6.6Z"
      />
    </svg>
  </button>

  <div class="a11y-panel" id="a11y-panel" hidden>
    <div class="a11y-head">
      <p class="a11y-title">{s.a11yTitle}</p>
      <button type="button" class="a11y-close" aria-label={s.a11yClose}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div class="a11y-group">
      <p class="a11y-label" id="a11y-text-size">{s.a11yTextSize}</p>
      <div class="a11y-steps" role="group" aria-labelledby="a11y-text-size">
        <button type="button" data-a11y="text-down" aria-label={s.a11ySmaller}>A−</button>
        <span class="a11y-scale-value" aria-live="polite">100%</span>
        <button type="button" data-a11y="text-up" aria-label={s.a11yLarger}>A+</button>
      </div>
    </div>

    <ul class="a11y-toggles">
      <li>
        <button type="button" data-a11y="contrast" aria-pressed="false">{s.a11yContrast}</button>
      </li>
      <li>
        <button type="button" data-a11y="links" aria-pressed="false">{s.a11yLinks}</button>
      </li>
      <li>
        <button type="button" data-a11y="motion" aria-pressed="false">{s.a11yMotion}</button>
      </li>
      <li>
        <button type="button" data-a11y="readable" aria-pressed="false">{s.a11yReadable}</button>
      </li>
    </ul>

    <button type="button" class="a11y-reset" data-a11y="reset">{s.a11yReset}</button>

    <p class="a11y-foot">
      {s.a11yTrouble} <a href="/accessibility" lang="he">{s.a11yStatement}</a>
    </p>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const fab = document.querySelector('.a11y-fab');
    const panel = document.getElementById('a11y-panel');
    if (!fab || !panel) return;

    const KEY = 'a11y-prefs';
    const TOGGLES = ['contrast', 'links', 'motion', 'readable'];
    const MIN = 1;
    const MAX = 1.5;

    /** @type {{scale:number, on:string[]}} */
    let prefs = { scale: 1, on: [] };
    try {
      const raw = localStorage.getItem(KEY);
      if (raw) prefs = { scale: 1, on: [], ...JSON.parse(raw) };
    } catch {
      /* private mode / blocked storage - the widget still works, it just won't persist */
    }

    const apply = () => {
      root.style.setProperty('--a11y-scale', String(prefs.scale));
      TOGGLES.forEach((t) => {
        const on = prefs.on.includes(t);
        root.classList.toggle('a11y-' + t, on);
        const btn = panel.querySelector(`[data-a11y="${t}"]`);
        if (btn) btn.setAttribute('aria-pressed', String(on));
      });
      const readout = panel.querySelector('.a11y-scale-value');
      if (readout) readout.textContent = Math.round(prefs.scale * 100) + '%';
      try {
        localStorage.setItem(KEY, JSON.stringify(prefs));
      } catch {
        /* ignore */
      }
    };

    const setOpen = (open) => {
      panel.hidden = !open;
      fab.setAttribute('aria-expanded', String(open));
      if (open) panel.querySelector('button')?.focus();
    };

    fab.addEventListener('click', () => setOpen(panel.hidden));
    panel.querySelector('.a11y-close')?.addEventListener('click', () => {
      setOpen(false);
      fab.focus();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) {
        setOpen(false);
        fab.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (!panel.hidden && !panel.contains(e.target) && !fab.contains(e.target)) setOpen(false);
    });

    panel.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-a11y]');
      if (!btn) return;
      const action = btn.dataset.a11y;

      if (action === 'text-up') prefs.scale = Math.min(MAX, +(prefs.scale + 0.1).toFixed(2));
      else if (action === 'text-down') prefs.scale = Math.max(MIN, +(prefs.scale - 0.1).toFixed(2));
      else if (action === 'reset') prefs = { scale: 1, on: [] };
      else if (TOGGLES.includes(action)) {
        prefs.on = prefs.on.includes(action)
          ? prefs.on.filter((t) => t !== action)
          : [...prefs.on, action];
      }
      apply();
    });

    apply();
  })();
</script>

<style>
  .a11y-fab {
    position: fixed;
    inset-inline-end: var(--sp-5);
    inset-block-end: var(--sp-5);
    z-index: 60;
    display: grid;
    place-items: center;
    inline-size: 3.75rem;
    block-size: 3.75rem;
    border: 0;
    border-radius: 50%;
    background: var(--c-teal);
    color: #fff;
    cursor: pointer;
    box-shadow: var(--shadow-lift);
    transition: background-color var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  /* Lifts on hover and drops back on press, like every other control on the site.
     The fill does darken here, unlike the buttons - this one is a circle with no
     label to wash out, and a colour shift is the clearest affordance it has. */
  .a11y-fab:hover {
    background: var(--c-teal-text);
    transform: translateY(-3px) scale(1.05);
  }

  .a11y-fab:active {
    transform: translateY(0) scale(1);
  }

  .a11y-panel {
    position: fixed;
    inset-inline-end: var(--sp-5);
    inset-block-end: calc(var(--sp-5) + 4.5rem);
    z-index: 61;
    inline-size: min(88vw, 20rem);
    display: grid;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: var(--c-surface);
    border: 1px solid var(--c-navy-08);
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-lift);
  }

  .a11y-panel[hidden] {
    display: none;
  }

  .a11y-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .a11y-title {
    font-family: var(--ff-title);
    font-size: var(--fs-h3);
    color: var(--c-navy);
  }

  .a11y-close {
    display: grid;
    place-items: center;
    inline-size: 2.25rem;
    block-size: 2.25rem;
    border: 0;
    border-radius: var(--radius-s);
    background: transparent;
    color: var(--c-navy);
    cursor: pointer;
  }

  .a11y-close:hover {
    background: var(--c-grey-soft);
    color: var(--c-teal-text);
  }

  .a11y-label {
    font-size: var(--fs-small);
    font-weight: var(--fw-bold);
    color: var(--c-steel);
    margin-block-end: var(--sp-2);
  }

  .a11y-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }

  .a11y-steps button {
    inline-size: 3rem;
    min-block-size: 2.75rem;
    border: 1px solid var(--c-teal-60);
    border-radius: var(--radius-m);
    background: var(--c-surface);
    color: var(--c-teal-text);
    font-weight: var(--fw-bold);
    cursor: pointer;
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .a11y-steps button:hover {
    background: var(--c-teal-tint);
  }

  .a11y-scale-value {
    font-weight: var(--fw-bold);
    color: var(--c-navy);
  }

  .a11y-toggles {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--sp-2);
  }

  .a11y-toggles button {
    inline-size: 100%;
    min-block-size: 2.75rem;
    padding-inline: var(--sp-4);
    text-align: start;
    border: 1px solid var(--c-navy-12);
    border-radius: var(--radius-m);
    background: var(--c-surface);
    color: var(--c-navy);
    cursor: pointer;
    transition: background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .a11y-toggles button:hover {
    background: var(--c-grey-soft);
    color: var(--c-teal-text);
  }

  .a11y-toggles button[aria-pressed='true'] {
    background: var(--c-teal);
    border-color: var(--c-teal);
    color: #fff;
  }

  .a11y-reset {
    min-block-size: 2.75rem;
    border: 0;
    border-radius: var(--radius-m);
    background: var(--c-grey-soft);
    color: var(--c-navy);
    font-weight: var(--fw-bold);
    cursor: pointer;
  }

  .a11y-reset:hover {
    background: var(--c-teal-tint);
    color: var(--c-teal-text);
  }

  .a11y-foot {
    font-size: var(--fs-small);
    color: var(--c-steel);
    text-align: center;
  }
</style>
